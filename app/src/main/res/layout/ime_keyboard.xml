                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/keyLanguage"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1.55"
                android:background="@drawable/ime_key_bg"
                android:textColor="@color/text_primary"
                android:text="@string/keyboard_lang_english" />

            <Button
                android:id="@+id/keySpace"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="3.2"
                android:background="@drawable/ime_key_bg"
                android:textColor="@color/text_primary"
                android:text="@string/keyboard_space" />

            <Button
                android:id="@+id/keyPeriod"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="0.85"
                android:background="@drawable/ime_key_bg"
                android:text="."
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/keyEnter"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1.45"
                android:background="@drawable/ime_key_bg"
                android:textColor="@color/text_primary"
                android:text="@string/keyboard_enter" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
